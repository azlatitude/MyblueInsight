{
  "expo": {
    "name": "MyBlueInsight",
    "slug": "myblueinsight",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myblueinsight",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.myblueinsight.app",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "MyBlueInsight saves your mood art to Photos"
      }
    },
    "android": {
      "package": "com.myblueinsight.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1e29fcdf-ee1b-4836-8b3f-a01807e735bf"
      }
    }
  }
}
